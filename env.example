# Copy to .env and edit before running setup.ps1 or setup.sh

# Public hostname for your Cloudflare Tunnel (no https:// prefix)
TUNNEL_HOSTNAME=ollama-you.example.com

# Cloudflare tunnel name (used with cloudflared tunnel create)
TUNNEL_NAME=cursor-ollama

# Ports
OLLAMA_PORT=11434
PROXY_PORT=11435

# Primary Ollama model to pull
OLLAMA_SOURCE_MODEL=qwen2.5-coder:7b

# Cursor-allowlisted name the proxy accepts (rewritten to OLLAMA_SOURCE_MODEL)
CURSOR_MODEL_NAME=gpt-4o-mini

# Generate a new key on setup, or set your own (min 16 chars recommended)
# OLLAMA_AUTH_KEY=

# Require Bearer auth on the proxy (recommended: true)
SECURE_TUNNEL=true

# Strategy: proxy-rewrite (default) | ollama-alias | custom-names
MODEL_ALIAS_STRATEGY=proxy-rewrite

# Path to cloudflared config directory
CLOUDFLARED_DIR=~/.cloudflared
